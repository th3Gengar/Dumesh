rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'arshiashokoufezamir@gmail.com';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
        request.resource.data.keys().hasAll(['id', 'email', 'displayName', 'publicKey', 'createdAt']) &&
        request.resource.data.keys().size() == 5 &&
        request.resource.data.id == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.displayName is string && request.resource.data.displayName.size() <= 64 &&
        request.resource.data.publicKey is string && request.resource.data.publicKey.size() <= 4096;
      
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) &&
        request.resource.data.id == userId &&
        request.resource.data.email == existing().email &&
        request.resource.data.displayName is string && request.resource.data.displayName.size() <= 64 &&
        request.resource.data.publicKey is string && request.resource.data.publicKey.size() <= 4096;
    }

    // Allowed Emails whitelist (Only writable by Admin)
    match /allowed_emails/{emailId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Groups Collection (Only writable by Admin)
    match /groups/{groupId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
      );
      allow write: if isAdmin();

      // Members subcollection rules
      match /members/{memberId} {
        allow read: if isSignedIn() && (
          isAdmin() || 
          exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
        );
        // Admin creates and registers key, or members update their own keys
        allow write: if isAdmin() || (
          isSignedIn() && isOwner(memberId) && 
          request.resource.data.keys().hasAll(['userId', 'email', 'displayName', 'encryptedGroupKey', 'createdAt']) &&
          request.resource.data.keys().size() == 5 &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.encryptedGroupKey is string && request.resource.data.encryptedGroupKey.size() <= 4096
        );
      }
    }

    // Chats Messages (E2E-encrypted payload)
    match /chats/{chatId}/messages/{messageId} {
      
      // Determine if chat is direct vs group
      // Direct: format direct_{uid1}_{uid2}
      // Group: format group_{groupId}
      
      function isDirectParticipant() {
        let parts = chatId.split('_');
        return parts.size() == 3 && parts[0] == 'direct' && (parts[1] == request.auth.uid || parts[2] == request.auth.uid);
      }

      function isGroupMember() {
        let parts = chatId.split('_');
        return parts.size() == 2 && parts[0] == 'group' && exists(/databases/$(database)/documents/groups/$(parts[1])/members/$(request.auth.uid));
      }

      allow read, write: if isSignedIn() && (
        isAdmin() ||
        isDirectParticipant() ||
        isGroupMember()
      );
    }

    // Telegram Channels (Only writable by Admin)
    match /telegram_channels/{channelId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /posts/{postId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(); // Server sync writes
      }
    }
  }
}
