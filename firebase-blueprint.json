{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account containing identity and client-side public key for hybrid encryption.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's UID" },
        "email": { "type": "string", "description": "The user's Google email" },
        "displayName": { "type": "string", "description": "The user's screen name" },
        "publicKey": { "type": "string", "description": "PEM or JWK format client-side public key for asymmetric encryption" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "email", "displayName"]
    },
    "Group": {
      "title": "Chat Group",
      "description": "Groups managed by the administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique Group ID" },
        "name": { "type": "string", "description": "The group name" },
        "description": { "type": "string", "description": "Group description" },
        "createdBy": { "type": "string", "description": "Admin UID who created the group" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "name", "createdBy"]
    },
    "GroupMember": {
      "title": "Group Member Key",
      "description": "Contains a group member's profile and their member-specific encrypted group symmetric key.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's UID" },
        "email": { "type": "string", "description": "The user's email" },
        "displayName": { "type": "string", "description": "The user's screen name" },
        "encryptedGroupKey": { "type": "string", "description": "The group's symmetric key, encrypted under this user's public key" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Joined timestamp" }
      },
      "required": ["userId", "email"]
    },
    "Message": {
      "title": "Encrypted Message",
      "description": "An E2E-encrypted message payload.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Message ID" },
        "senderId": { "type": "string", "description": "Sender user UID" },
        "senderName": { "type": "string", "description": "Sender display name" },
        "encryptedPayload": { "type": "string", "description": "The actual text/content, encrypted symmetrically" },
        "encryptedSymmetricKeys": {
          "type": "object",
          "description": "For 1-on-1 direct messages, map of uid -> message key encrypted by that uid's public key."
        },
        "isGroup": { "type": "boolean", "description": "Whether message belongs to a group" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server creation timestamp" }
      },
      "required": ["id", "senderId", "senderName", "encryptedPayload"]
    },
    "TelegramChannel": {
      "title": "Telegram Channel Connection",
      "description": "A public Telegram channel monitored for posts.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The Telegram channel handle/username (without @)" },
        "displayName": { "type": "string", "description": "Channel display name" },
        "description": { "type": "string", "description": "Channel description snippet" },
        "lastSyncedAt": { "type": "string", "format": "date-time", "description": "Last synced timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registry date" }
      },
      "required": ["id", "displayName"]
    },
    "TelegramPost": {
      "title": "Telegram Channel Post",
      "description": "A parsed post fetched from a registered Telegram channel.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Post numeric ID or unique combination" },
        "postId": { "type": "string", "description": "ID of post within Telegram channel context" },
        "text": { "type": "string", "description": "Message body" },
        "mediaUrl": { "type": "string", "description": "Optional parsed image attachment link" },
        "date": { "type": "string", "description": "The post's date" },
        "fetchedAt": { "type": "string", "format": "date-time", "description": "Timestamp when server scraped this post" }
      },
      "required": ["id", "postId", "text"]
    },
    "AllowedEmail": {
      "title": "Allowed Email",
      "description": "A whitelist of emails uploaded/assigned by the admin.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "The allowed Google email adress" },
        "displayName": { "type": "string", "description": "Assigned name for the user" },
        "assignedGroups": { "type": "array", "description": "Array of group IDs assigned to this email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "White-list creation date" }
      },
      "required": ["email", "displayName"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Registered and authorized user accounts."
    },
    "groups": {
      "schema": "Group",
      "description": "Admin-created discussion groups."
    },
    "groups/{groupId}/members": {
      "schema": "GroupMember",
      "description": "Subcollection mapping user memberships and their encrypted group key."
    },
    "chats/{chatId}/messages": {
      "schema": "Message",
      "description": "Historical message flows for direct and group rooms (fully encrypted)."
    },
    "telegram_channels": {
      "schema": "TelegramChannel",
      "description": "Public Telegram channel handles linked in the platform."
    },
    "telegram_channels/{channelId}/posts": {
      "schema": "TelegramPost",
      "description": "Monitored posts fetched under the specific channel."
    },
    "allowed_emails": {
      "schema": "AllowedEmail",
      "description": "The administrator whitelist of authorized emails."
    }
  }
}
